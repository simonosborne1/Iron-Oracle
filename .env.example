# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Serper.dev (Google Search API) — get key at serper.dev
SERPER_API_KEY=your-serper-api-key-here

# Claude model
CLAUDE_MODEL=claude-sonnet-4-6

# SQLite database file path (relative to backend/)
DATABASE_PATH=./iron_oracle.db

# PDF limits
PDF_MAX_SIZE_MB=50
PDF_DOWNLOAD_TIMEOUT_SECONDS=30

# Cache TTL
MANUAL_CACHE_TTL_DAYS=30
TORQUE_CACHE_TTL_DAYS=90

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Environment
ENVIRONMENT=development
